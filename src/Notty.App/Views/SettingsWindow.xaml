<Window x:Class="Notty.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Settings" Width="580" Height="430"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" FontFamily="Segoe UI" FontSize="13"
        Background="{DynamicResource WindowBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,10,0" />
            <Setter Property="MinWidth" Value="90" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Margin" Value="0,8,0,0" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Width" Value="200" />
            <Setter Property="HorizontalAlignment" Value="Left" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Button DockPanel.Dock="Bottom" Content="Close" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right" Margin="16" IsCancel="True" IsDefault="True"
                Click="Close_Click" />

        <TabControl TabStripPlacement="Left" Margin="12,12,12,0"
                    Background="Transparent" BorderBrush="{DynamicResource BorderBrushSoft}">

            <!-- ===== Appearance ===== -->
            <TabItem Header="Appearance">
                <StackPanel Margin="16">
                    <TextBlock Text="Theme" Style="{StaticResource SectionHeader}" />
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Color theme" Style="{StaticResource FieldLabel}" />
                        <ComboBox ItemsSource="{Binding Themes}" SelectedItem="{Binding SelectedTheme, Mode=TwoWay}" />
                    </StackPanel>
                    <TextBlock Text="Drop a .json palette into the themes folder to add your own."
                               Foreground="{DynamicResource MutedTextBrush}" FontSize="11"
                               TextWrapping="Wrap" Margin="0,10,0,0" />
                </StackPanel>
            </TabItem>

            <!-- ===== Editor ===== -->
            <TabItem Header="Editor">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <TextBlock Text="Font" Style="{StaticResource SectionHeader}" />
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Font family" Style="{StaticResource FieldLabel}" />
                            <ComboBox ItemsSource="{Binding FontFamilies}"
                                      SelectedItem="{Binding SelectedFontFamily, Mode=TwoWay}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <TextBlock Text="Font size" Style="{StaticResource FieldLabel}" />
                            <ComboBox Width="80" HorizontalAlignment="Left" ItemsSource="{Binding FontSizes}"
                                      SelectedItem="{Binding SelectedFontSize, Mode=TwoWay}" />
                        </StackPanel>

                        <!-- Live preview of the selected font family + size -->
                        <Border Margin="0,10,0,0" CornerRadius="4" Padding="10"
                                BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1"
                                Background="{DynamicResource WindowBackgroundBrush}">
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextBrush}"
                                       FontFamily="{Binding SelectedFontFamily}"
                                       FontSize="{Binding SelectedFontSize}"
                                       Text="The quick brown fox jumps over the lazy dog&#x0A;0123456789  # Heading  `code`  ( ) { } [ ]" />
                        </Border>

                        <TextBlock Text="Formatting" Style="{StaticResource SectionHeader}" Margin="0,16,0,4" />
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Tab width" Style="{StaticResource FieldLabel}" />
                            <ComboBox Width="80" HorizontalAlignment="Left" ItemsSource="{Binding TabWidths}"
                                      SelectedItem="{Binding SelectedTabWidth, Mode=TwoWay}" />
                        </StackPanel>
                        <CheckBox Content="Word wrap" IsChecked="{Binding WordWrap, Mode=TwoWay}" />
                        <CheckBox Content="Show line numbers" IsChecked="{Binding ShowLineNumbers, Mode=TwoWay}" />
                        <CheckBox Content="Highlight current line" IsChecked="{Binding HighlightCurrentLine, Mode=TwoWay}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ===== Files ===== -->
            <TabItem Header="Files">
                <StackPanel Margin="16">
                    <TextBlock Text="Saving" Style="{StaticResource SectionHeader}" />
                    <CheckBox Content="Auto-save changes (otherwise save with Ctrl+S)"
                              IsChecked="{Binding AutoSave, Mode=TwoWay}" />

                    <TextBlock Text="Tree" Style="{StaticResource SectionHeader}" Margin="0,16,0,4" />
                    <CheckBox Content="Show unsupported file types (with a ? icon)"
                              IsChecked="{Binding ShowUnsupportedFiles, Mode=TwoWay}" />
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>

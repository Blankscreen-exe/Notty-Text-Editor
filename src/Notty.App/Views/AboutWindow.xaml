<Window x:Class="Notty.App.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svg="clr-namespace:SharpVectors.Converters;assembly=SharpVectors.Converters.Wpf"
        Title="About Notty" Width="380" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        ShowInTaskbar="False" FontFamily="Segoe UI" FontSize="13"
        Background="{DynamicResource WindowBackgroundBrush}">

    <StackPanel Margin="28,28,28,22" HorizontalAlignment="Center">
        <svg:SvgViewbox Source="pack://application:,,,/Assets/Branding/notty-logo.svg"
                        Width="92" Height="92" HorizontalAlignment="Center" />

        <TextBlock Text="Notty" FontSize="28" FontWeight="Bold"
                   Foreground="{DynamicResource TextBrush}"
                   HorizontalAlignment="Center" Margin="0,14,0,0" />

        <TextBlock x:Name="VersionText" Foreground="{DynamicResource MutedTextBrush}"
                   HorizontalAlignment="Center" Margin="0,2,0,0" />

        <TextBlock Text="A file-based notes manager."
                   Foreground="{DynamicResource TextBrush}"
                   HorizontalAlignment="Center" Margin="0,14,0,0" />

        <TextBlock Text="Your notes are plain .md and .txt files on disk — no database, no lock-in."
                   Foreground="{DynamicResource MutedTextBrush}" FontSize="12"
                   TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />

        <Button Content="Close" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Center" Margin="0,20,0,0"
                IsCancel="True" IsDefault="True" Click="Close_Click" />
    </StackPanel>
</Window>
